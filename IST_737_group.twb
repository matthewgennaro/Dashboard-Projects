                    <capturedDeltas>
                      <dashboard name='Intro'>
                        <zone id='5'>
                          <formatted-text>
                            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Visualizing the Effects that Professional Sports has on Crime</run>
                            <run>Æ&#10;&#10;</run>
                            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>By: Alice Galvao Vieira, Ashish Kushwaha, Harika Gangu, Lakshmi Peram, Matthew Gennaro</run>
                            <run>Æ&#10;&#10;</run>
                            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Data From: Baseball Reference, Basketball Reference, Hockey Reference, Pro Football Reference, and FBI.</run>
                          </formatted-text>
                        </zone>
                      </dashboard>
                    </capturedDeltas>
                  </story-point>
