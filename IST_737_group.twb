        <calculation class='tableau' formula='IIF([Playoffs] == &quot;Champion&quot;, &quot;Champion&quot;, &#13;&#10;    IIF([Playoffs] == &quot;No&quot;, &quot;No Playoffs&quot;,&quot;Playoff Appearance&quot;))' />
      </column>
      <column caption='Time_of_Day' datatype='real' name='[Calculation_1859142289577840640]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='Case [incident_hour]&#13;&#10;    WHEN [incident_hour] &lt;= 6 THEN &quot;Early Morning&quot;&#13;&#10;    WHEN [incident_hour] &gt; 6 AND [incident_hour] &lt;=12 THEN &quot;Morning&quot;&#13;&#10;    WHEN [incident_hour] &gt; 12 AND [incident_hour] &lt;= 18 THEN &quot;Afternoon&quot;&#13;&#10;    WHEN [incident_hour] &gt; 18 THEN &quot;Night&quot;&#13;&#10;END' />
      </column>
      <column caption='Offenses_Condensed' datatype='string' name='[Calculation_2937754397899059200]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [offense_category_name]&#13;&#10;    WHEN &quot;Assault Offenses&quot; THEN &quot;Assault Offenses&quot;&#13;&#10;    WHEN &quot;Destruction/Damage/Vandalism of Property&quot; THEN &quot;Destruction/Damage/Vandalism of Property&quot;&#13;&#10;    WHEN &quot;Larceny/Theft Offenses&quot; THEN &quot;Larceny/Theft Offenses&quot;&#13;&#10;    WHEN &quot;Drug/Narcotic Offenses&quot; THEN &quot;Drug/Narcotic Offenses&quot;&#13;&#10;    WHEN &quot;Fraud Offenses&quot; THEN &quot;Fraud&quot;&#13;&#10;    WHEN &quot;Robbery&quot; THEN &quot;Robbery&quot;&#13;&#10;    WHEN &quot;Motor Vehicle Theft&quot; THEN &quot;Motor Vehicle Theft&quot;&#13;&#10;    WHEN &quot;Burglary/Breaking &amp; Entering&quot; THEN &quot;Burglary/Breaking &amp; Entering&quot;&#13;&#10;    ELSE &quot;Other&quot;&#13;&#10;END' />
      </column>
      <column caption='Number Teams' datatype='integer' name='[Calculation_670191983060045824]' role='measure' type='ordinal'>
